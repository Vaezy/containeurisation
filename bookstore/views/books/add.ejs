<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>Ajouter un Livre</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
  </head>
  <body class="container mt-5">
    <h1>Ajouter un nouveau livre</h1>
    <hr />

    <form action="/books/add" method="POST" class="col-md-6">
      <div class="mb-3">
        <label for="title" class="form-label">Titre du livre</label>
        <input
          type="text"
          class="form-control"
          id="title"
          name="title"
          required
        />
      </div>
      <div class="mb-3">
        <label for="author" class="form-label">Auteur</label>
        <input
          type="text"
          class="form-control"
          id="author"
          name="author"
          required
        />
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description / Résumé</label>
        <textarea
          class="form-control"
          id="description"
          name="description"
          rows="3"
        ></textarea>
      </div>

      <button type="submit" class="btn btn-success">
        Enregistrer (Submit)
      </button>
      <a href="/books" class="btn btn-secondary">Retour</a>
    </form>
  </body>
</html>
