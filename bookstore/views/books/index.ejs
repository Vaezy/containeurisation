<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ma Bibliothèque</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Liste des Livres</h1>
        <a href="/books/add" class="btn btn-primary">➕ Ajouter un livre</a>
    </div>

    <% if (msg) { %>
        <div class="alert alert-success"><%= msg %></div>
    <% } %>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(book => { %>
                <tr>
                    <td><strong><%= book.title %></strong></td>
                    <td><%= book.author %></td>
                    <td>
                        <a href="/books/<%= book.id %>" class="btn btn-info btn-sm">Voir</a>
                        <a href="/books/<%= book.id %>/edit" class="btn btn-warning btn-sm">Modifier</a>
                        <a href="/books/<%= book.id %>/delete" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce livre ?')">Supprimer</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>