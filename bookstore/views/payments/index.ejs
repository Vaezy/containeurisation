<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Gestion des Paiements</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Liste des Paiements</h1>
    <div>
      <a href="/orders" class="btn btn-secondary">Voir les Commandes</a>
      <a href="/payments/add" class="btn btn-primary">+ Nouveau Paiement</a>
    </div>
  </div>

  <% if (msg) { %>
    <div class="alert alert-success"><%= msg %></div>
  <% } %>

  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>ID Paiement</th>
        <th>ID Commande</th>
        <th>Montant</th>
        <th>Date</th>
        <th>Méthode</th>
        <th>Statut</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (payments.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center">Aucun paiement enregistré.</td>
        </tr>
      <% } else { %>
        <% payments.forEach(payment => { %>
          <tr>
            <td><%= payment.id %></td>
            <td><%= payment.orderId %></td>
            <td><%= payment.amount %> €</td>
            <td><%= payment.paymentDate %></td>
            <td><%= payment.paymentMethod || 'Non spécifiée' %></td>
            <td>
              <span class="badge <%= payment.status === 'Validé' ? 'bg-success' : 'bg-danger' %>">
                <%= payment.status %>
              </span>
            </td>
            <td>
              <a href="/payments/<%= payment.id %>/edit" class="btn btn-sm btn-warning">Modifier</a>
              <a href="/payments/<%= payment.id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ce paiement ?')">Supprimer</a>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

</body>
</html>